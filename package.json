{
  "name": "git-scribe-ai",
  "displayName": "GitScribe AI",
  "description": "AI-powered Git assistant: commit messages, README generation, reports",
  "version": "1.1.0",
  "icon": "img/icon.png",
  "publisher": "Ilnsk",
  "repository": {
    "type": "git",
    "url": "https://github.com/DemonDis/GitScribe-AI.git"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gitScribe-sidebar",
          "title": "GitScribe AI",
          "icon": "assets/icon_sidebar.svg"
        }
      ]
    },
    "views": {
      "gitScribe-sidebar": [
        {
          "type": "tree",
          "id": "gitScribe-sidebar-view",
          "name": "GitScribe AI"
        }
      ]
    },
    "menus": {
      "scm/title": [
        {
          "command": "gitScribe.generateCommit",
          "icon": {
            "light": "assets/icon.svg",
            "dark": "assets/icon.svg"
          },
          "group": "navigation",
          "when": "scmProvider == git && scm hasChanges"
        }
      ]
    },
    "commands": [
      {
        "command": "gitScribe.openSettings",
        "title": "GitScribe AI: Open Settings"
      },
      {
        "command": "gitScribe.generateCommit",
        "title": "GitScribe AI: Generate Commit Message",
        "icon": {
          "light": "assets/icon.svg",
          "dark": "assets/icon.svg"
        }
      },
      {
        "command": "gitScribe.generateReadme",
        "title": "GitScribe AI: Generate README"
      },
      {
        "command": "gitScribe.updateReadme",
        "title": "GitScribe AI: Update README"
      },
      {
        "command": "gitScribe.generateReport",
        "title": "GitScribe AI: Generate Report"
      }
    ],
    "keybindings": [
      {
        "command": "gitScribe.generateCommit",
        "key": "ctrl+shift+g",
        "mac": "cmd+shift+g"
      }
    ],
    "configuration": {
      "title": "GitScribe AI",
      "properties": {
        "gitscribe.apiUrl": {
          "type": "string",
          "default": "",
          "description": "API URL (e.g., https://api.openai.com/v1)"
        },
        "gitscribe.apiKey": {
          "type": "string",
          "default": "",
          "description": "API Key"
        },
        "gitscribe.model": {
          "type": "string",
          "default": "",
          "description": "Model name (e.g., gpt-4o, deepseek-chat)"
        },
        "gitscribe.gitProvider": {
          "type": "string",
          "default": "gitlab",
          "enum": [
            "gitlab",
            "github"
          ],
          "enumDescriptions": [
            "GitLab",
            "GitHub"
          ],
          "description": "Git provider for API integration"
        },
        "gitscribe.gitlabUrl": {
          "type": "string",
          "default": "",
          "description": "GitLab server URL (e.g., https://gitlab.com)"
        },
        "gitscribe.gitlabToken": {
          "type": "string",
          "default": "",
          "description": "GitLab personal access token"
        },
        "gitscribe.githubToken": {
          "type": "string",
          "default": "",
          "description": "GitHub personal access token (classic with repo scope)"
        },
        "gitscribe.rejectUnauthorized": {
          "type": "boolean",
          "default": false,
          "description": "Disable TLS certificate verification (rejectUnauthorized)"
        },
        "gitscribe.gitmoji": {
          "type": "boolean",
          "default": false,
          "description": "Enable gitmoji in commit messages"
        },
        "gitscribe.prompt": {
          "type": "string",
          "default": "",
          "description": "Custom prompt template for commit message generation. Use {diff} as placeholder for the diff content."
        },
        "gitscribe.customPrompts": {
          "type": "object",
          "default": {},
          "description": "Custom overrides for prompt files. Keys are file paths (e.g. 'readme.md'), values are prompt content."
        },
        "gitscribe.reportAuthorOnly": {
          "type": "boolean",
          "default": true,
          "description": "Report: show only my commits (filter by git config user.email)"
        },
        "gitscribe.reportAuthorFilter": {
          "type": "string",
          "default": "",
          "description": "Report: show only commits by this author email (leave empty for all commits)"
        },
        "gitscribe.language": {
          "type": "string",
          "default": "en",
          "enum": [
            "en",
            "ru"
          ],
          "enumDescriptions": [
            "English",
            "Русский"
          ],
          "description": "Language for the settings panel UI"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "rm -rf out && esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"No linter yet\"",
    "test": "echo \"No tests yet\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.28.1",
    "husky": "^9.1.7",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "simple-git": "^3.22.0"
  }
}
