{
  "name": "git-scribe-ai",
  "displayName": "GitScribe AI",
  "description": "AI-powered Git assistant: commit messages, README generation, reports",
  "version": "1.0.0",
  "icon": "img/icon.png",
  "publisher": "git-scribe-ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/DemonDis/GitScribe-AI.git"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gitScribe-sidebar",
          "title": "GitScribe AI",
          "icon": "assets/icon.svg"
        }
      ]
    },
    "views": {
      "gitScribe-sidebar": [
        {
          "type": "tree",
          "id": "gitScribe-sidebar-view",
          "name": "GitScribe AI"
        }
      ]
    },
    "menus": {
      "scm/title": [
        {
          "command": "gitScribe.generateCommit",
          "icon": {
            "light": "assets/icon.svg",
            "dark": "assets/icon.svg"
          },
          "group": "navigation",
          "when": "scmProvider == git && scm hasChanges"
        }
      ]
    },
    "commands": [
      {
        "command": "gitScribe.openSettings",
        "title": "GitScribe AI: Open Settings"
      },
      {
        "command": "gitScribe.setup",
        "title": "GitScribe AI: Setup Configuration"
      },
      {
        "command": "gitScribe.generateCommit",
        "title": "GitScribe AI: Generate Commit Message",
        "icon": {
          "light": "assets/icon.svg",
          "dark": "assets/icon.svg"
        }
      },
      {
        "command": "gitScribe.generateReadme",
        "title": "GitScribe AI: Generate README"
      },
      {
        "command": "gitScribe.updateReadme",
        "title": "GitScribe AI: Update README"
      },

      {
        "command": "gitScribe.generateReport",
        "title": "GitScribe AI: Generate Report"
      }
    ],
    "keybindings": [
      {
        "command": "gitScribe.generateCommit",
        "key": "ctrl+shift+g",
        "mac": "cmd+shift+g"
      }
    ],
    "configuration": {
      "title": "GitScribe AI",
      "properties": {
        "gitscribe.apiUrl": {
          "type": "string",
          "default": "",
          "description": "API URL (e.g., https://api.openai.com/v1)"
        },
        "gitscribe.apiKey": {
          "type": "string",
          "default": "",
          "description": "API Key"
        },
        "gitscribe.model": {
          "type": "string",
          "default": "",
          "description": "Model name (e.g., gpt-4o, deepseek-chat)"
        },
        "gitscribe.gitlabUrl": {
          "type": "string",
          "default": "",
          "description": "GitLab instance URL"
        },
        "gitscribe.gitlabToken": {
          "type": "string",
          "default": "",
          "description": "GitLab Personal Access Token"
        },
        "gitscribe.rejectUnauthorized": {
          "type": "boolean",
          "default": false,
          "description": "Disable TLS certificate verification (rejectUnauthorized)"
        },
        "gitscribe.gitmoji": {
          "type": "boolean",
          "default": false,
          "description": "Enable gitmoji in commit messages"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "echo \"No linter yet\"",
    "test": "echo \"No tests yet\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "husky": "^9.1.7",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "openai": "^4.0.0",
    "repomix": "^1.16.0",
    "simple-git": "^3.22.0"
  }
}
